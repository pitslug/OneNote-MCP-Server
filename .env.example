# OneNote MCP Sidekick — environment reference.
# In Docker, prefer the *_FILE variants (Docker secrets) for anything sensitive.
# A plain VAR always overrides its VAR_FILE.

# --- Required: your own Azure app registration (public client) ---
# Register at https://portal.azure.com ; scopes Notes.ReadWrite, offline_access, User.Read.
AZURE_CLIENT_ID=
# AZURE_CLIENT_ID_FILE=/run/secrets/onenote_client_id

# --- Gateway auth: bearer token the MCP client (Claude) must send ---
# Generate a long random value, e.g.  openssl rand -hex 32
# Leave empty to disable the app-layer gate (then rely on Traefik / network trust).
ONENOTE_API_TOKEN=
# ONENOTE_API_TOKEN_FILE=/run/secrets/onenote_api_token

# --- Connector OAuth (claude.ai custom connectors; optional) ---
# claude.ai can't send a static bearer header — it needs spec OAuth. Setting
# ONENOTE_OIDC_CONFIG_URL turns on an OIDC proxy in front of your identity provider
# (e.g. Pocket-ID); all four values are then required (partial config refuses to boot).
# The static ONENOTE_API_TOKEN keeps working alongside. See DEPLOY.md.
# ONENOTE_OIDC_CONFIG_URL=https://id.example.net/.well-known/openid-configuration
# ONENOTE_OIDC_CLIENT_ID=
# ONENOTE_OIDC_CLIENT_SECRET=
# ONENOTE_OIDC_CLIENT_SECRET_FILE=/run/secrets/onenote_oidc_client_secret
# ONENOTE_PUBLIC_BASE_URL=https://onenote.example.net
# Scopes requested from the IdP (space/comma separated; must not be empty).
# ONENOTE_OIDC_SCOPES=openid profile email

# --- Transport ---
ONENOTE_TRANSPORT=streamable-http      # or: stdio (local Claude Desktop dev)
ONENOTE_HTTP_HOST=0.0.0.0
ONENOTE_HTTP_PORT=8400
ONENOTE_HTTP_PATH=/mcp
ONENOTE_ENABLE_AUTH_ROUTE=true         # expose /auth device-code sign-in page

# --- Microsoft auth / token cache ---
AZURE_AUTHORITY=https://login.microsoftonline.com/consumers
ONENOTE_CACHE_TOKENS=true
ONENOTE_TOKEN_CACHE=/data/tokens/token_cache.json
# ONENOTE_TOKEN_CACHE_SEED_FILE=/run/secrets/onenote_token_seed
ONENOTE_GRAPH_TIMEOUT=60
ONENOTE_MAX_RETRIES=4
ONENOTE_COPY_WAIT=60                   # seconds to poll an async page copy before returning the operation id

# --- Target notebook / write-back section ---
ONENOTE_SIDEKICK_NOTEBOOK=Slugbook
ONENOTE_SIDEKICK_SECTION=Sidekick

# --- Notebook cache (speed of access) ---
ONENOTE_CACHE_ENABLED=true
ONENOTE_DATA_CACHE=/data/cache
ONENOTE_LISTING_TTL=60                 # seconds; listings freshness
ONENOTE_INK_REVALIDATE=30              # seconds before re-checking lastModified
ONENOTE_CACHE_MAX_MB=500               # disk budget before LRU eviction

# --- Logging ---
ONENOTE_LOG_LEVEL=INFO
